{
  "enabled": true,
  "name": "Ruff Lint & Fix",
  "description": "Executa ruff check --fix nos arquivos Python do backend ao salvar, aplicando correções automáticas de linting.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/**/*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "docker compose exec backend ruff check --fix .",
    "timeout": 30
  }
}