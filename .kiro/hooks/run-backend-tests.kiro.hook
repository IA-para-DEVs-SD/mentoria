{
  "enabled": true,
  "name": "Run Backend Tests",
  "description": "Executa os testes unitários do backend via Docker quando um arquivo de teste é editado. Se houver falhas, pede ao agente para corrigi-las.",
  "version": "2",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/tests/test_*.py"
    ]
  },
  "then": {
    "type": "askAgent",
    "prompt": "Execute os testes do backend com: docker compose exec backend python3 -m pytest tests/ --tb=short -q. Se houver falhas, analise os erros e corrija os testes automaticamente. Após corrigir, rode os testes novamente para confirmar que todos passam."
  }
}
