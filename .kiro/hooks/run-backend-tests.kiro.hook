{
  "enabled": true,
  "name": "Run Backend Tests",
  "description": "Executa os testes unitários do backend via Docker quando um arquivo de teste é editado.",
  "version": "1",
  "when": {
    "type": "fileEdited",
    "patterns": [
      "backend/tests/test_*.py"
    ]
  },
  "then": {
    "type": "runCommand",
    "command": "docker compose exec backend python3 -m pytest tests/ -v 2>&1",
    "timeout": 60
  }
}